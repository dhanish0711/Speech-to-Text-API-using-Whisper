# Environment Variables for Speech-to-Text API
# Copy this file to .env and edit as needed

# Whisper model size: tiny | base | small | medium | large | large-v3
WHISPER_MODEL=base

# Maximum upload size in bytes (default: 100 MB)
MAX_FILE_SIZE_BYTES=104857600

# Minimum audio duration considered non-empty (seconds)
MIN_AUDIO_DURATION_SECONDS=0.1

# Temporary directory for audio processing
TEMP_DIR=/tmp
